#include <stdio.h>

typedef struct {
    int day;
    int month;
    int year;
} Date;

int is_later(Date d1, Date d2) {
    if (d1.year != d2.year) return d1.year > d2.year;
    if (d1.month != d2.month) return d1.month > d2.month;
    return d1.day > d2.day;
}

int main() {
    FILE *f = fopen("f.txt", "r");
    FILE *g = fopen("g.txt", "w");

    if (!f || !g) return 1;

    Date dates[100];
    int count = 0;

    while (fscanf(f, "%d %d %d", &dates[count].day, &dates[count].month, &dates[count].year) == 3) {
        count++;
    }

    if (count == 0) return 0;

 
    int min_year = dates[0].year;
    for (int i = 1; i < count; i++) {
        if (dates[i].year < min_year) min_year = dates[i].year;
    }
    fprintf(g, "а) Наименьший год: %d\n", min_year);

   
    fprintf(g, "б) Весенние даты: ");
    for (int i = 0; i < count; i++) {
        if (dates[i].month >= 3 && dates[i].month <= 5) {
            fprintf(g, "%02d.%02d.%d ", dates[i].day, dates[i].month, dates[i].year);
        }
    }

    // Самая поздняя дата
    Date latest = dates[0];
    for (int i = 1; i < count; i++) {
        if (is_later(dates[i], latest)) latest = dates[i];
    }
    fprintf(g, "\nв) Самая поздняя дата: %02d.%02d.%d\n", latest.day, latest.month, latest.year);

    fclose(f);
    fclose(g);
    return 0;
}
