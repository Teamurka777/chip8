#include <stdio.h>

int main() {
    FILE *f = fopen("f.txt", "r");
    FILE *g = fopen("g.txt", "w");

    if (f == NULL || g == NULL) {
        printf("Ошибка открытия файлов.\n");
        return 1;
    }

    fseek(f, 0, SEEK_END);
    
    long pos = ftell(f);

    while (pos > 0) {
        fseek(f, --pos, SEEK_SET);
        
        int ch = fgetc(f);
        if (ch != EOF) {
            fputc(ch, g);
        }
    }
    fclose(f);
    fclose(g);

    printf("Файл g успешно создан. Данные записаны в обратном порядке.\n");
    return 0;
}

